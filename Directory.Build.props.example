<!--
  Copy this file to Directory.Build.props (gitignored) and set deploy targets.

  Per-host deploy:
    MendixDeployTarget10x — Concord.Host10x.dll deploys here (extensions/Concord10x/)
    MendixDeployTarget11x — Concord.Host11x.dll deploys here (extensions/Concord11x/)

  Each accepts a semicolon-separated list of project roots.

  Studio Pro 10.x crashes if it sees Concord11x/ in its extensions/ folder
  (type-resolution failure on 11.x ExtensionsAPI types), and vice versa. So a
  dev working across both Studio Pro versions needs two separate test
  projects — one for each host.

  Single-host setups (only working on one Studio Pro version): set just the
  matching property and ignore the other.

  Fallback:
    MendixDeployTarget — used by either host if its per-host override is unset.

  Examples:

    Cross-version dev (two test projects):
      <MendixDeployTarget10x>C:\Projects\Test_10_24_13</MendixDeployTarget10x>
      <MendixDeployTarget11x>C:\Projects\Test_11_10</MendixDeployTarget11x>

    Single-version dev (11.x only):
      <MendixDeployTarget11x>C:\Projects\MyApp</MendixDeployTarget11x>

    Legacy single-target (deprecated — works for both hosts but both extension
    folders land in the same project, which crashes the wrong-version Studio
    Pro):
      <MendixDeployTarget>C:\Projects\MyApp</MendixDeployTarget>
-->
<Project>
  <PropertyGroup>
    <MendixDeployTarget10x></MendixDeployTarget10x>
    <MendixDeployTarget11x></MendixDeployTarget11x>
    <!-- Per-developer; set this to the path of your Mendix project root (e.g.
         C:\Workspace\MendixApps\TestOSApp3) to enable the unified shim deploy.
         Falls back to $(MendixDeployTarget) if unset. Deploys bin/x64/.../net8.0-merged/
         to <target>/extensions/Concord/ — the v5.1.0+ runtime-shim layout. -->
    <MendixDeployTargetMerged></MendixDeployTargetMerged>
    <!-- Mendix.StudioPro.ExtensionsAPI version compatible with Studio Pro 10.24.13.
         10.21.1 matches the version MCPExtension uses for 10.24 support. -->
    <ExtensionsApi10xVersion>10.21.1</ExtensionsApi10xVersion>
    <!-- Baseline ExtensionsAPI version for Concord.Shim. Must be <= 10.21.1 so
         the shim DLL forward-compatibly loads on both SP 10.24.13 and SP 11.10.
         Phase 0 spike confirmed 10.21.1 resolves to 10.24.13.0 on SP10 and
         11.10.0.0 on SP11. Do not raise this without re-running the spike. -->
    <ExtensionsApiShimBaselineVersion>10.21.1</ExtensionsApiShimBaselineVersion>
  </PropertyGroup>
</Project>
