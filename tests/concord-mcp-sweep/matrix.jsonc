  // ---- Block 1: DomainModel mutations (targets first) ----

  ,{
    "name": "create_module",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "module_name": "ConcordSweep_create_module" },
    "expected": "ok",
    "notes": "Creates sweep-owned module; used as rename_module target in Block 7. [idempotency: matrix re-runs against pre-existing project state] [tightened to expected:ok 2026-05-14 after fresh-state validation; see phase4-fresh-state-validation.md]"
  }
  ,{
    "name": "create_entity",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "module_name": "MyFirstModule", "entity_name": "SweepEntity_create_entity" },
    "expected": "ok",
    "verify": { "name": "query_model_elements", "args": { "type_name": "DomainModels$Entity", "module_name": "MyFirstModule", "max_results": 50 } },
    "notes": "Creates primary sweep entity; many subsequent entries depend on this entity existing."
  }
  ,{
    "name": "create_multiple_entities",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "module_name": "MyFirstModule", "entities": [{ "entity_name": "SweepEntityA_create_multiple_entities" }, { "entity_name": "SweepEntityB_create_multiple_entities" }] },
    "expected": "ok",
    "notes": "Creates two additional sweep entities; auto-arranges domain model after creation."
  }
  ,{
    "name": "create_domain_model_from_schema",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "module_name": "MyFirstModule", "schema": { "entities": [{ "name": "SweepEntity_create_domain_model_from_schema", "attributes": [{ "name": "Title", "type": "String" }] }] } },
    "expected": "ok",
    "notes": "Creates entity from JSON schema; auto-arranges after creation."
  }
  ,{
    "name": "add_attribute",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "SweepEntity_create_entity", "attribute_name": "SweepAttr_add_attribute", "attribute_type": "String", "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Adds SweepAttr_add_attribute to SweepEntity_create_entity; depends on create_entity."
  }
  ,{
    "name": "update_attribute",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "SweepEntity_create_entity", "attribute_name": "SweepAttr_add_attribute", "type": "String", "max_length": 200, "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Updates SweepAttr_add_attribute max_length; depends on add_attribute."
  }
  ,{
    "name": "rename_attribute",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "SweepEntity_create_entity", "attribute_name": "SweepAttr_add_attribute", "new_name": "SweepAttr_rename_attribute", "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Renames SweepAttr_add_attribute → SweepAttr_rename_attribute; depends on add_attribute. [idempotency: on re-runs, SweepAttr_rename_attribute already exists — 'Name is not valid or is not unique' — because entity may survive from a prior partial run. expected:either.] [tightened to expected:ok 2026-05-14 after fresh-state validation; see phase4-fresh-state-validation.md]"
  }
  ,{
    "name": "set_calculated_attribute",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "Customer", "attribute_name": "FullName", "microflow": "MyFirstModule.CAL_Customer_FullName" },
    "expected": "either",
    "notes": "Sets calculated microflow on Customer.FullName; expected: either (microflow may not exist in test project)."
  }
  ,{
    "name": "configure_system_attributes",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "SweepEntity_create_entity", "module_name": "MyFirstModule", "has_created_date": true, "has_changed_date": true },
    "expected": "ok",
    "notes": "Enables createdDate/changedDate system attributes on SweepEntity_create_entity; entity must have no generalization."
  }
  ,{
    "name": "add_event_handler",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "Customer", "event": "commit", "moment": "before", "microflow": "MyFirstModule.BCO_Customer_BeforeCommit" },
    "expected": "either",
    "notes": "Adds before-commit event handler; expected: either (BCO microflow may not exist in test project)."
  }
  ,{
    "name": "set_documentation",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "element_type": "entity", "element_name": "SweepEntity_create_entity", "documentation": "Sweep test entity created by concord-mcp-sweep.", "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Sets documentation on SweepEntity_create_entity; depends on create_entity."
  }
  ,{
    "name": "rename_entity",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "SweepEntity_create_entity", "new_name": "SweepEntityRenamed_rename_entity", "module_name": "MyFirstModule" },
    "expected": "ok",
    "verify": { "name": "query_model_elements", "args": { "type_name": "DomainModels$Entity", "module_name": "MyFirstModule", "max_results": 50 } },
    "notes": "Renames SweepEntity_create_entity → SweepEntityRenamed_rename_entity; closes create→rename→delete cycle."
  }
  ,{
    "name": "set_entity_generalization",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "Order", "parent_entity": "Administration.FileDocument", "module_name": "MyFirstModule" },
    "expected": "either",
    "notes": "Sets generalization on Order entity; expected: either (Administration module may not exist or Order may already have generalization)."
  }
  ,{
    "name": "remove_entity_generalization",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "entity_name": "Order", "module_name": "MyFirstModule" },
    "expected": "either",
    "notes": "Removes generalization from Order; expected: either (depends on set_entity_generalization succeeding)."
  }
  ,{
    "name": "copy_model_element",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "element_type": "entity", "source_name": "Customer", "new_name": "SweepEntity_copy", "source_module": "MyFirstModule" },
    "expected": "ok",
    "notes": "Copies Customer entity to SweepEntity_copy within MyFirstModule; BUG-013 fix: target_module defaults to source_module."
  }
  ,{
    "name": "create_association",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "name": "Customer_Orders", "parent": "Customer", "child": "Order", "module_name": "MyFirstModule" },
    "expected": "either",
    "notes": "Creates Customer_Orders association; expected: either (association may already exist in test project)."
  }
  ,{
    "name": "create_multiple_associations",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "associations": [{ "name": "SweepEntityA_create_multiple_entities_SweepEntityB_create_multiple_entities", "parent": "SweepEntityA_create_multiple_entities", "child": "SweepEntityB_create_multiple_entities" }], "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Creates association between sweep-created entities; depends on create_multiple_entities. [idempotency: matrix re-runs against pre-existing project state] [tightened to expected:ok 2026-05-14 after fresh-state validation; see phase4-fresh-state-validation.md]"
  }
  ,{
    "name": "update_association",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "association_name": "Customer_Orders", "owner": "both", "module_name": "MyFirstModule" },
    "expected": "either",
    "notes": "Updates Customer_Orders owner to both; expected: either (depends on create_association succeeding or pre-existing)."
  }
  ,{
    "name": "rename_association",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "association_name": "Customer_Orders", "new_name": "Customer_OrderItems", "module_name": "MyFirstModule" },
    "expected": "either",
    "notes": "Renames Customer_Orders → Customer_OrderItems; expected: either (depends on create_association succeeding)."
  }
  ,{
    "name": "arrange_domain_model",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Arranges domain model layout for MyFirstModule; non-fatal if layout engine unavailable."
  }
  ,{
    "name": "manage_folders",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "action": "list", "module_name": "MyFirstModule" },
    "expected": "ok",
    "notes": "Lists folders in MyFirstModule; action=list is read-safe and always available."
  }
  ,{
    "name": "rename_document",
    "family": "DomainModel",
    "phase": "mutate",
    "args": { "document_name": "ACT_Example", "new_name": "ACT_ExampleRenamed", "module_name": "MyFirstModule", "document_type": "microflow" },
    "expected": "either",
    "notes": "Renames ACT_Example microflow; expected: either (ACT_Example may not exist in test project)."
  }

  // ---- Block 2: ConstantsEnums mutations ----

  ,{
    "name": "create_enumeration",
    "family": "ConstantsEnums",
    "phase": "mutate",
    "args": { "name": "SweepEnum_create_enumeration", "module_name": "MyFirstModule", "values": ["Draft", "Submitted", "Approved"] },
    "expected": "ok",
    "notes": "Creates SweepEnum_create_enumeration with 3 values; used by update_enumeration and rename_enumeration_value. [idempotency: matrix re-runs against pre-existing project state] [tightened to expected:ok 2026-05-14 after fresh-state validation; see phase4-fresh-state-validation.md]"
  }
  ,{
    "name": "update_enumeration",
    "family": "ConstantsEnums",
    "phase": "mutate",
    "args": { "enumeration_name": "SweepEnum_create_enumeration", "add_values": ["Cancelled"], "module_name": "MyFirstModule" },
    "expected": "ok",
